/scripts/probe-*
/scripts/explore-*
/scripts/dump-*
/scripts/capture-khalti-*
/scripts/khalti-*.md
/scripts/khalti-*.log

# Local exports (CSV history exports default to CWD)
*.csv

# Claude Code project-local config (keep settings, ignore local overrides)
.claude/settings.local.json

# Project planning notes (kept local)
/plan/
